{
  "name": "shopeasy-api-automation",
  "version": "1.0.0",
  "description": "API Automation Testing Suite for ShopEasy Order Management API",
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test tests/auth",
    "test:products": "playwright test tests/products",
    "test:cart": "playwright test tests/cart",
    "test:orders": "playwright test tests/orders",
    "test:payments": "playwright test tests/payments",
    "test:e2e": "playwright test tests/e2e",
    "test:report": "playwright test && playwright show-report reports/playwright-report",
    "coverage:matrix": "ts-node artifacts/coverageMatrix.ts",
    "test:inventory": "ts-node artifacts/testCaseInventory.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
